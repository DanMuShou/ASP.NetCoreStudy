@using _250321_rider_ViewsExample.Models
@{
    //嵌入到html的代码块
    var appTitle = "Asp.Net Core Demo App";
    // var person = new Person()
    // {
    //     Name = "Rider",
    //     DateOfBirth = Convert.ToDateTime("1980-01-01"),
    //     PersonGender = Gender.Female,
    // };

    List<Person> persons =
    [
        new Person() { Name = "Rider", DateOfBirth = Convert.ToDateTime("1980-01-01"), PersonGender = Gender.Female },
        new Person() { Name = "Vs", DateOfBirth = Convert.ToDateTime("1980-01-01"), PersonGender = Gender.Female },
        new Person() { Name = "VsCode", DateOfBirth = null, PersonGender = Gender.Female }
    ];
}

@* functions 可以定义为本地类 而不是局部函数 *@

@functions{

    //本地方法
    double? GetAge(DateTime? dateOfBrith)
    {
        if (!dateOfBrith.HasValue) return null;
        return System.Math.Round((DateTime.Now - dateOfBrith.Value).TotalDays / 365.25);
    }

    int x = 10;

    string Name { get; set; } = "Hello name";
}

